# Base de datos (PostgreSQL — Neon, Supabase, Azure Database for PostgreSQL, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# JWT — genera un secreto aleatorio fuerte:
# node -e "require('crypto').randomBytes(48).toString('base64url') |> console.log"
JWT_SECRET="genera-uno-con: node -e \"require('crypto').randomBytes(48).toString('base64url') |> console.log\""

# Solo si usas Prisma con credenciales separadas (opcional)
# PGUSER=
# PGPASSWORD=
